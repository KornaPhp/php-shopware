{% block sw_settings_country_preview_template %}
<div
    class="sw-settings-country-preview-template"
    :class="{ 'is--loading': isLoading }"
    :aria-busy="isLoading ? 'true' : 'false'"
>
    <sw-loader
        v-if="isLoading"
        class="sw-settings-country-preview-template__loader"
        size="16px"
    />

    <div
        class="sw-settings-country-preview-template__content"
        v-html="displayFormattingAddress"
    ></div>
</div>
{% endblock %}
